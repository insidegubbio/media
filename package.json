    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^8.3.0",
    "@github/webauthn-json": "^2.1.1",
    "@mantine/charts": "^8.3.9",
    "@mantine/code-highlight": "^8.3.9",
    "@mantine/core": "^8.3.9",
